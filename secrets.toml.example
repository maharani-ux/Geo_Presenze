# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT: fill in values and run `streamlit run Home.py`
# STREAMLIT CLOUD:   go to App → Settings → Secrets and paste this
# ─────────────────────────────────────────────────────────────
# ⚠️  NEVER commit this file to GitHub — it is in .gitignore

SECRET_KEY   = "change-me-to-a-long-random-string"
DATABASE_URL = "sqlite:///presenze.db"

# To use PostgreSQL (recommended for production):
# DATABASE_URL = "postgresql://user:password@host:5432/dbname"
# Get a free Postgres DB at: https://supabase.com or https://neon.tech
